{
  "$defs": {
    "AIInfo": {
      "additionalProperties": false,
      "properties": {
        "generated_fields": {
          "items": {
            "type": "string"
          },
          "title": "Generated Fields",
          "type": "array"
        },
        "source": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source"
        },
        "created_on": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Created On"
        },
        "review_state": {
          "anyOf": [
            {
              "enum": [
                "pending",
                "approved",
                "rejected"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Review State"
        }
      },
      "title": "AIInfo",
      "type": "object"
    },
    "ApprovalHistoryEntry": {
      "additionalProperties": false,
      "properties": {
        "action": {
          "enum": [
            "reviewed",
            "approved",
            "published"
          ],
          "title": "Action",
          "type": "string"
        },
        "by": {
          "minLength": 1,
          "title": "By",
          "type": "string"
        },
        "acted_on": {
          "format": "date",
          "title": "Acted On",
          "type": "string"
        }
      },
      "required": [
        "action",
        "by",
        "acted_on"
      ],
      "title": "ApprovalHistoryEntry",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "id": {
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "title": "Id",
      "type": "string"
    },
    "kind": {
      "const": "resource",
      "title": "Kind",
      "type": "string"
    },
    "status": {
      "enum": [
        "candidate",
        "reviewed",
        "approved",
        "published"
      ],
      "title": "Status",
      "type": "string"
    },
    "visibility": {
      "enum": [
        "private",
        "teacher",
        "student",
        "public"
      ],
      "title": "Visibility",
      "type": "string"
    },
    "languages": {
      "items": {
        "enum": [
          "en",
          "nb"
        ],
        "type": "string"
      },
      "title": "Languages",
      "type": "array"
    },
    "title": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Title",
      "type": "object"
    },
    "courses": {
      "items": {
        "type": "string"
      },
      "title": "Courses",
      "type": "array"
    },
    "topics": {
      "items": {
        "type": "string"
      },
      "title": "Topics",
      "type": "array"
    },
    "tags": {
      "items": {
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    },
    "outputs": {
      "items": {
        "enum": [
          "html",
          "pdf",
          "revealjs",
          "handout",
          "exercise-sheet"
        ],
        "type": "string"
      },
      "title": "Outputs",
      "type": "array"
    },
    "owners": {
      "items": {
        "type": "string"
      },
      "title": "Owners",
      "type": "array"
    },
    "updated": {
      "format": "date",
      "title": "Updated",
      "type": "string"
    },
    "translation_status": {
      "additionalProperties": {
        "enum": [
          "missing",
          "machine_draft",
          "edited",
          "approved"
        ],
        "type": "string"
      },
      "title": "Translation Status",
      "type": "object"
    },
    "ai": {
      "$ref": "#/$defs/AIInfo"
    },
    "resource_kind": {
      "enum": [
        "article",
        "paper",
        "podcast",
        "video",
        "book",
        "chapter",
        "website"
      ],
      "title": "Resource Kind",
      "type": "string"
    },
    "authors": {
      "items": {
        "type": "string"
      },
      "title": "Authors",
      "type": "array"
    },
    "published_on": {
      "format": "date",
      "title": "Published On",
      "type": "string"
    },
    "url": {
      "format": "uri",
      "minLength": 1,
      "title": "Url",
      "type": "string"
    },
    "difficulty": {
      "enum": [
        "introductory",
        "intermediate",
        "advanced"
      ],
      "title": "Difficulty",
      "type": "string"
    },
    "estimated_time_minutes": {
      "exclusiveMinimum": 0,
      "title": "Estimated Time Minutes",
      "type": "integer"
    },
    "summary": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Summary",
      "type": "object"
    },
    "why_selected": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Why Selected",
      "type": "object"
    },
    "instructor_note": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Instructor Note",
      "type": "object"
    },
    "freshness": {
      "enum": [
        "evergreen",
        "time-sensitive"
      ],
      "title": "Freshness",
      "type": "string"
    },
    "review_after": {
      "anyOf": [
        {
          "format": "date",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Review After"
    },
    "approved_by": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Approved By"
    },
    "approved_on": {
      "anyOf": [
        {
          "format": "date",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Approved On"
    },
    "approval_history": {
      "items": {
        "$ref": "#/$defs/ApprovalHistoryEntry"
      },
      "title": "Approval History",
      "type": "array"
    },
    "stale_flag": {
      "default": false,
      "title": "Stale Flag",
      "type": "boolean"
    }
  },
  "required": [
    "id",
    "kind",
    "status",
    "visibility",
    "languages",
    "title",
    "updated",
    "resource_kind",
    "published_on",
    "url",
    "difficulty",
    "estimated_time_minutes",
    "freshness"
  ],
  "title": "Resource",
  "type": "object"
}