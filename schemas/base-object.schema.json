{
  "$defs": {
    "AIInfo": {
      "additionalProperties": false,
      "properties": {
        "generated_fields": {
          "items": {
            "type": "string"
          },
          "title": "Generated Fields",
          "type": "array"
        },
        "source": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source"
        },
        "created_on": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Created On"
        },
        "review_state": {
          "anyOf": [
            {
              "enum": [
                "pending",
                "approved",
                "rejected"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Review State"
        }
      },
      "title": "AIInfo",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "id": {
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "title": "Id",
      "type": "string"
    },
    "kind": {
      "enum": [
        "concept",
        "exercise",
        "figure",
        "resource",
        "collection"
      ],
      "title": "Kind",
      "type": "string"
    },
    "status": {
      "title": "Status",
      "type": "string"
    },
    "visibility": {
      "enum": [
        "private",
        "teacher",
        "student",
        "public"
      ],
      "title": "Visibility",
      "type": "string"
    },
    "languages": {
      "items": {
        "enum": [
          "en",
          "nb"
        ],
        "type": "string"
      },
      "title": "Languages",
      "type": "array"
    },
    "title": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Title",
      "type": "object"
    },
    "courses": {
      "items": {
        "type": "string"
      },
      "title": "Courses",
      "type": "array"
    },
    "topics": {
      "items": {
        "type": "string"
      },
      "title": "Topics",
      "type": "array"
    },
    "tags": {
      "items": {
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    },
    "outputs": {
      "items": {
        "enum": [
          "html",
          "pdf",
          "revealjs",
          "handout",
          "exercise-sheet"
        ],
        "type": "string"
      },
      "title": "Outputs",
      "type": "array"
    },
    "owners": {
      "items": {
        "type": "string"
      },
      "title": "Owners",
      "type": "array"
    },
    "updated": {
      "format": "date",
      "title": "Updated",
      "type": "string"
    },
    "translation_status": {
      "additionalProperties": {
        "enum": [
          "missing",
          "machine_draft",
          "edited",
          "approved"
        ],
        "type": "string"
      },
      "title": "Translation Status",
      "type": "object"
    },
    "ai": {
      "$ref": "#/$defs/AIInfo"
    }
  },
  "required": [
    "id",
    "kind",
    "status",
    "visibility",
    "languages",
    "title",
    "updated"
  ],
  "title": "BaseContentModel",
  "type": "object"
}