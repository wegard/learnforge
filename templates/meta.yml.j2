id: {{ id }}
kind: {{ kind }}
status: {{ "candidate" if kind == "resource" else "approved" }}
visibility: student
languages:
  - en
  - nb
title:
  en: {{ title_en }}
  nb: {{ title_nb }}
courses: []
topics: []
tags: []
outputs:
  - html
owners:
  - {{ owner }}
updated: {{ updated }}
translation_status:
  en: {{ "edited" if kind == "resource" else "approved" }}
  nb: {{ "machine_draft" if kind == "resource" else "approved" }}
ai:
  generated_fields: []
{% if kind == "concept" %}
level: intermediate
prerequisites: []
related: []
{% elif kind == "exercise" %}
exercise_type: conceptual
difficulty: easy
estimated_time_minutes: 10
concepts: []
solution_visibility: teacher
{% elif kind == "figure" %}
concepts: []
caption:
  en: Replace with an English caption.
  nb: Erstatt med en norsk bildetekst.
alt_text:
  en: Replace with English alt text.
  nb: Erstatt med norsk alternativ tekst.
svg_path: figure.svg
pdf_path: figure.pdf
interactive_path:
asset_inventory:
  - figure.svg
  - figure.pdf
{% elif kind == "resource" %}
resource_kind: article
authors:
  - {{ owner }}
published_on: {{ updated }}
url: https://example.org/{{ id }}
difficulty: introductory
estimated_time_minutes: 15
summary:
  en: Add a short English summary.
  nb: Legg til et kort norsk sammendrag.
why_selected:
  en: Explain why the resource matters.
  nb: Forklar hvorfor ressursen er nyttig.
instructor_note:
  en: Add instructor guidance here.
  nb: Legg til faglærermerknad her.
freshness: evergreen
approval_history: []
stale_flag: false
{% elif kind == "collection" %}
collection_kind: {{ collection_kind }}
items: []
{% endif %}
